{
    "name": "pluma-engine-panel",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc --noEmit && vite build",
        "test": "vitest run",
        "test:watch": "vitest",
        "wp-env": "wp-env",
        "test:integration": "wp-env run tests-cli --env-cwd=wp-content/plugins/pluma-engine env WP_TESTS_PHPUNIT_POLYFILLS_PATH=vendor/yoast/phpunit-polyfills composer test:integration",
        "test:e2e": "playwright test"
    },
    "dependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "devDependencies": {
        "@playwright/test": "^1.61.1",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.0.1",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^6.0.4",
        "@wordpress/env": "^11.11.0",
        "jsdom": "^25.0.1",
        "typescript": "^5.7.2",
        "vite": "^8.1.5",
        "vitest": "^4.1.10"
    }
}

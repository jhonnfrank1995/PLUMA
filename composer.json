{
    "name": "pluma/pluma-engine",
    "description": "PLUMA Engine — sala de redaccion sintetica para WordPress: deteccion de tendencias, investigacion multifuente, periodistas sinteticos, motor SEO, taxonomia, compuertas de calidad/riesgo/originalidad y publicacion autonoma.",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0",
        "brain/monkey": "^2.6",
        "phpstan/phpstan": "^1.11",
        "phpstan/extension-installer": "^1.4",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "humbug/php-scoper": "^0.18"
    },
    "autoload": {
        "psr-4": {
            "Pluma\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pluma\\Tests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "8.2"
        },
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "analyse": "phpstan analyse --memory-limit=1536M",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit -c phpunit-integration.xml.dist"
    }
}
